{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "bash hooks/scripts/docs-reminder.sh",
            "timeout": 3000
          },
          {
            "type": "command",
            "command": "bash hooks/scripts/cli-plugin-sync.sh",
            "timeout": 3000
          }
        ]
      }
    ]
  }
}
