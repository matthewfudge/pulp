<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<!-- iOS HostApp entitlements for a Pulp AUv3 container.
     The app-group entitlement matches the AUv3 .appex's entitlement so
     the HostApp + extension can share preset storage via NSFileCoordinator
     in App-Group container URLs. -->
<plist version="1.0">
<dict>
    <key>com.apple.security.application-groups</key>
    <array>
        <string>group.@PLUGIN_BUNDLE_ID@</string>
    </array>
</dict>
</plist>
