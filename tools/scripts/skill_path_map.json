{
  "$schema": "./skill_path_map.schema.json",
  "schema_version": 1,
  "_comment": "Skill name -> glob patterns. When a diff touches any pattern, the corresponding SKILL.md must be updated in the same diff or a Skill-Update: skip trailer must appear on the tip commit. Paired with tools/scripts/versioning.json. Every subdir under .agents/skills/ MUST have an entry here; skill_sync_check.py fails if one is missing. Dual/triple ownership is permitted — and expected — for files that span multiple domains: e.g. core/format/src/au_adapter.mm is owned by both `auv3` (the adapter) and `view-bridge` (editor attach lifecycle), because a change to that file reasonably requires guidance updates on both sides. Dual ownership is not a mistake to collapse; use it when a single file legitimately teaches two skills.",
  "skills": {
    "aax": {
      "paths": [
        "core/format/src/aax*",
        "core/format/include/pulp/format/aax*",
        "external/AAX-SDK/**",
        "tools/cmake/PulpAAX.cmake"
      ],
      "_doc": {
        "empty-ok": "external/AAX-SDK/** intentionally empty — AAX SDK is developer-supplied per docs/guides/ship.md and the aax skill"
      }
    },
    "ara": {
      "paths": [
        "core/format/src/ara*",
        "core/format/include/pulp/format/ara*",
        "core/format/include/pulp/format/ara/**",
        "external/ara-sdk/**"
      ],
      "_doc": {
        "empty-ok": "external/ara-sdk/** intentionally empty — ARA SDK is developer-supplied per the ara skill"
      }
    },
    "auv3": {
      "paths": [
        "core/format/src/au_adapter.mm",
        "core/format/src/au_entry.mm",
        "core/format/src/au_audio_unit.h",
        "core/format/src/au_view_controller_ios.mm",
        "core/format/src/ios_audio_session.cpp",
        "core/format/include/pulp/format/ios_audio_session.h",
        "core/format/include/pulp/format/ios_audio_session.hpp",
        "tools/cmake/PulpInfoPlist.au.in"
      ]
    },
    "android": {
      "paths": [
        "core/render/platform/android/**",
        "core/audio/platform/android/**",
        "core/view/platform/android/**",
        "core/midi/platform/android/**",
        "android/**",
        "tools/cmake/PulpAndroid.cmake",
        "tools/build-skia-android.sh",
        "tools/scripts/android_smoke.sh",
        "docs/guides/platforms/android.md"
      ]
    },
    "auv2": {
      "paths": [
        "core/format/src/au_v2_adapter.cpp",
        "core/format/src/au_v2_instrument.cpp",
        "core/format/src/au_v2_cocoa_view.mm",
        "core/format/include/pulp/format/au_v2_adapter.hpp",
        "core/format/include/pulp/format/au_v2_instrument.hpp",
        "core/format/include/pulp/format/au_v2_entry.hpp",
        "core/format/include/pulp/format/au_v2_instrument_entry.hpp",
        "tools/cmake/PulpInfoPlist.au.in",
        "test/test_au_v2_*",
        "test/cmake/test_au_v2_*"
      ]
    },
    "ci": {
      "paths": [
        ".github/workflows/**",
        "ci/**",
        "tools/local-ci/**",
        "tools/shipyard.toml",
        "tools/install-shipyard.sh",
        "tools/scripts/install-githooks.sh",
        ".githooks/**"
      ]
    },
    "clap": {
      "paths": [
        "core/format/src/clap_adapter.cpp",
        "core/format/include/pulp/format/clap_adapter.hpp",
        "core/format/include/pulp/format/clap_entry.hpp"
      ]
    },
    "cli-maintenance": {
      "paths": [
        "tools/cli/**",
        "tools/mcp/pulp_mcp.cpp",
        "docs/status/cli-commands.yaml",
        "tools/scripts/cli_sync_check.py",
        ".claude/commands/**"
      ]
    },
    "cmajor-external": {
      "paths": [
        "tools/scripts/cmajor_external.py",
        "tools/scripts/test_cmajor_external.py",
        "examples/cmajor-*/**"
      ]
    },
    "engine": {
      "paths": [
        "core/view/src/js_*",
        "core/view/include/pulp/view/js_engine*",
        "core/view/src/script_engine*",
        "core/view/include/pulp/view/script_engine*",
        "core/view/js/web-compat-*.js",
        "external/quickjs*/**"
      ],
      "_doc": {
        "empty-ok": "external/quickjs*/** intentionally empty — QuickJS is fetched at configure time, not vendored"
      }
    },
    "faust": {
      "paths": [
        "examples/faust-*/**",
        "core/dsl/include/pulp/dsl/faust*",
        "tools/cmake/PulpFaust.cmake"
      ]
    },
    "hosting": {
      "paths": [
        "core/host/**",
        "examples/plugin-host-demo/**",
        "tools/cli/cmd_host.cpp"
      ]
    },
    "ios": {
      "paths": [
        "core/view/platform/ios/**",
        "core/format/src/au_view_controller_ios.mm",
        "tools/cmake/ios.toolchain.cmake",
        "templates/ios-auv3/**",
        "examples/ios-auv3-*/**"
      ]
    },
    "import-design": {
      "paths": [
        "tools/import-design/**",
        "tools/design/**",
        "core/view/src/design_import*",
        "core/view/include/pulp/view/design_import.hpp",
        "core/view/js/import-runtime.js"
      ]
    },
    "jsfx-subset": {
      "paths": [
        "tools/scripts/jsfx_subset.py",
        "tools/scripts/test_jsfx_subset.py",
        "examples/jsfx-*/**"
      ]
    },
    "mpe": {
      "paths": [
        "core/midi/include/**/*mpe*",
        "core/midi/include/**/*ump*",
        "examples/mpe-*/**"
      ]
    },
    "packages": {
      "paths": [
        "tools/packages/**",
        "DEPENDENCIES.md",
        "NOTICE.md",
        "tools/deps/manifest.json"
      ]
    },
    "prototype-loop": {
      "paths": [
        "tools/cli/cmd_loop.cpp",
        "docs/guides/focus-mode.md",
        ".claude/commands/prototype-loop.md"
      ]
    },
    "sdf-text": {
      "paths": [
        "core/canvas/src/*sdf*",
        "core/canvas/src/*msdf*",
        "core/canvas/include/**/*sdf*",
        "core/canvas/include/**/*msdf*",
        "core/canvas/include/**/*psdf*",
        "examples/sdf-*/**"
      ]
    },
    "ship": {
      "paths": [
        "ship/**",
        "tools/cli/cmd_ship.cpp",
        "tools/scripts/release-cli-local.sh",
        ".github/workflows/sign-and-release.yml",
        ".github/workflows/release-cli.yml"
      ]
    },
    "streams": {
      "paths": [
        "core/runtime/src/*stream*",
        "core/runtime/include/**/*stream*",
        "examples/stream-*/**"
      ]
    },
    "threejs-bridge": {
      "paths": [
        "examples/threejs-*/**"
      ]
    },
    "upgrade": {
      "paths": [
        "tools/cli/cmd_upgrade.cpp",
        "tools/cli/migration_index.hpp",
        "tools/cli/migration_runtime.cpp",
        "tools/scripts/build_migration_index.py",
        "tools/scripts/cli_version_check.sh",
        "docs/migrations/**",
        ".claude/commands/upgrade.md"
      ]
    },
    "view-bridge": {
      "paths": [
        "core/format/src/view_bridge.cpp",
        "core/format/include/pulp/format/view_bridge.hpp",
        "core/format/include/pulp/format/processor.hpp",
        "core/format/src/vst3_plug_view.cpp",
        "core/format/include/pulp/format/vst3_plug_view.hpp",
        "core/format/include/pulp/format/clap_adapter.hpp",
        "core/format/include/pulp/format/clap_entry.hpp",
        "core/format/src/standalone.cpp",
        "core/format/src/au_v2_cocoa_view.mm",
        "core/format/src/au_adapter.mm",
        "core/format/src/au_view_controller_ios.mm",
        "core/view/include/pulp/view/editor_bridge.hpp",
        "core/view/src/editor_bridge.cpp",
        "examples/view-bridge-demo/**"
      ]
    },
    "vst3": {
      "paths": [
        "core/format/src/vst3_adapter.cpp",
        "core/format/include/pulp/format/vst3_adapter.hpp",
        "core/format/include/pulp/format/vst3_entry.hpp",
        "tools/cmake/PulpInfoPlist.vst3.in"
      ]
    },
    "webview-ui": {
      "paths": [
        "examples/webview-*/**"
      ]
    }
  }
}
