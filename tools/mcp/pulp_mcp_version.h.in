#pragma once
// Generated by tools/mcp/CMakeLists.txt from project(VERSION ...). Wires
// the MCP server's advertised serverInfo.version to the actual SDK/CLI
// version so `pulp doctor` and the launcher can see real drift. The
// hard-coded "0.1.0" we used pre-#2067 made every fresh install look
// identical even after upgrades.
#define PULP_MCP_SERVER_VERSION "@PROJECT_VERSION@"
