{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://pulp.dev/schemas/pulp-package-v1.schema.json",
  "title": "Pulp Package Manifest",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "schema",
    "id",
    "name",
    "version",
    "license",
    "licenses",
    "kind",
    "capabilities",
    "exports",
    "dependencies",
    "validation"
  ],
  "properties": {
    "schema": {
      "const": "pulp-package-v1"
    },
    "id": {
      "type": "string",
      "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]*$"
    },
    "name": {
      "type": "string",
      "minLength": 1
    },
    "version": {
      "type": "string",
      "pattern": "^[0-9][A-Za-z0-9.+-]*$"
    },
    "license": {
      "type": "string",
      "minLength": 1
    },
    "licenses": {
      "type": "object",
      "additionalProperties": {
        "type": "string",
        "minLength": 1
      }
    },
    "kind": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "enum": ["source", "ui-kit", "template", "content-pack", "node-pack", "native-component"]
      },
      "uniqueItems": true
    },
    "audience": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": ["developer", "agent", "end-user"]
      },
      "uniqueItems": true
    },
    "description": {
      "type": "string"
    },
    "requires": {
      "type": "object",
      "properties": {
        "pulp": { "type": "string" },
        "cpp": { "type": "integer" },
        "platforms": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": ["macOS", "Windows", "Linux", "iOS", "Android", "WASM", "AUv3"]
          },
          "uniqueItems": true
        }
      }
    },
    "capabilities": {
      "type": "array",
      "items": { "type": "string" },
      "uniqueItems": true
    },
    "exports": {
      "type": "object",
      "properties": {
        "pulpUiScripts": { "type": "array", "items": { "type": "string" } },
        "designTokens": { "type": "array", "items": { "type": "string" } },
        "assets": { "type": "array", "items": { "type": "string" } },
        "templates": { "type": "array", "items": { "type": "string" } },
        "validationReports": { "type": "array", "items": { "type": "string" } },
        "screenshots": { "type": "array", "items": { "type": "string" } },
        "presets": { "type": "array", "items": { "type": "string" } },
        "themes": { "type": "array", "items": { "type": "string" } },
        "samples": { "type": "array", "items": { "type": "string" } },
        "wavetables": { "type": "array", "items": { "type": "string" } },
        "licenses": { "type": "array", "items": { "type": "string" } },
        "sourceFiles": { "type": "array", "items": { "type": "string" } },
        "nativeComponentHeaders": { "type": "array", "items": { "type": "string" } },
        "nativeComponentSources": { "type": "array", "items": { "type": "string" } },
        "nodePackManifests": { "type": "array", "items": { "type": "string" } },
        "graphFixtures": { "type": "array", "items": { "type": "string" } },
        "stateFixtures": { "type": "array", "items": { "type": "string" } }
      },
      "additionalProperties": true
    },
    "dependencies": {
      "type": "object",
      "properties": {
        "pulp": {
          "type": "array",
          "items": { "type": "string" }
        },
        "packages": {
          "type": "array",
          "items": { "type": "string" }
        }
      },
      "additionalProperties": false
    },
    "realtime": {
      "type": "object",
      "properties": {
        "processSafe": { "type": "boolean" },
        "allocatesInProcess": { "type": "boolean" },
        "locksInProcess": { "type": "boolean" },
        "notes": { "type": "string" }
      }
    },
    "agent": {
      "type": "object",
      "properties": {
        "guidance": { "type": "string" },
        "autoApply": { "type": "boolean" }
      }
    },
    "authoring": {
      "type": "object",
      "properties": {
        "createdBy": {
          "oneOf": [
            {
              "type": "string",
              "enum": ["human", "agent", "mixed"]
            },
            {
              "type": "object",
              "required": ["type"],
              "properties": {
                "type": {
                  "type": "string",
                  "enum": ["human", "agent", "mixed"]
                },
                "tool": { "type": "string" },
                "toolVersion": { "type": "string" }
              },
              "additionalProperties": true
            }
          ]
        },
        "humanReviewed": { "type": "boolean" },
        "humanReview": {
          "type": "object",
          "properties": {
            "requiredBeforePublish": { "type": "boolean" },
            "reviewed": { "type": "boolean" },
            "reviewer": { "type": "string" },
            "reviewedAt": { "type": "string" }
          },
          "additionalProperties": true
        }
      }
    },
    "validation": {
      "type": "object",
      "properties": {
        "profiles": {
          "type": "array",
          "items": { "type": "string" }
        },
        "reports": {
          "type": "array",
          "items": { "type": "string" }
        },
        "generatedProjectDiffs": {
          "type": "array",
          "items": { "type": "string" }
        }
      },
      "additionalProperties": true
    },
    "evidence": {
      "type": "object",
      "properties": {
        "screenshots": {
          "type": "array",
          "items": { "$ref": "#/definitions/evidenceItem" }
        },
        "reports": {
          "type": "array",
          "items": { "$ref": "#/definitions/evidenceItem" }
        },
        "validationReports": {
          "type": "array",
          "items": { "$ref": "#/definitions/evidenceItem" }
        }
      },
      "additionalProperties": true
    }
  },
  "allOf": [
    {
      "if": {
        "required": ["kind"],
        "properties": {
          "kind": {
            "contains": { "const": "template" }
          }
        }
      },
      "then": {
        "required": ["validation"],
        "properties": {
          "validation": {
            "required": ["generatedProjectDiffs"],
            "properties": {
              "generatedProjectDiffs": {
                "minItems": 1
              }
            }
          }
        }
      }
    },
    {
      "if": {
        "required": ["kind"],
        "properties": {
          "kind": {
            "contains": { "const": "ui-kit" }
          }
        }
      },
      "then": {
        "required": ["evidence"],
        "properties": {
          "evidence": {
            "anyOf": [
              {
                "required": ["screenshots"],
                "properties": {
                  "screenshots": {
                    "minItems": 1
                  }
                }
              },
              {
                "required": ["reports"],
                "properties": {
                  "reports": {
                    "minItems": 1
                  }
                }
              }
            ]
          }
        }
      }
    }
  ],
  "definitions": {
    "evidenceItem": {
      "oneOf": [
        { "type": "string" },
        {
          "type": "object",
          "required": ["path"],
          "properties": {
            "id": { "type": "string" },
            "path": { "type": "string" },
            "caption": { "type": "string" },
            "tool": { "type": "string" },
            "sdkVersion": { "type": "string" },
            "status": { "type": "string" },
            "sha256": {
              "type": "string",
              "pattern": "^sha256-[0-9a-fA-F]{64}$"
            }
          },
          "additionalProperties": true
        }
      ]
    }
  }
}
