{
  "version": "DOM4 + HTML5 living-standard subset",
  "source": "https://html.spec.whatwg.org/multipage/ + https://dom.spec.whatwg.org/ + core/view/js/web-compat-{element,document,dom-ops}.js",
  "_doc": "Each entry describes what the catalog row CLAIMS to bind to. The adapter cross-checks the claim against (a) Element.prototype / Object.defineProperty patterns in web-compat-element.js, (b) document.* members in web-compat-document.js, and (c) bridge function registrations in core/view/src/widget_bridge.cpp.",
  "categories": {
    "element_method": "Element.prototype.X = function(...)",
    "element_property": "Object.defineProperty(Element.prototype, 'X', {...})",
    "document_member": "document = { X: ... } in web-compat-document.js",
    "html_tag": "Tag handled by Element.prototype._ensureNative dispatch -> create* bridge function",
    "feature": "Higher-level feature that touches multiple artifacts (ARIA, StyleSheet_inline, DocumentFragment, Event_constructor)"
  },
  "entries": {
    "html/Element_addEventListener": {
      "category": "element_method",
      "js_member": "addEventListener",
      "spec": "https://dom.spec.whatwg.org/#dom-eventtarget-addeventlistener",
      "expected_event_types": [
        "click",
        "mouseenter",
        "mouseleave",
        "mouseover",
        "mouseout",
        "mousedown",
        "mouseup",
        "mousemove",
        "pointerenter",
        "pointerleave",
        "pointerover",
        "pointerout",
        "pointerdown",
        "pointermove",
        "pointerup",
        "pointercancel",
        "gesturestart",
        "gesturechange",
        "gestureend",
        "change",
        "input",
        "focus",
        "blur",
        "keydown",
        "keyup",
        "keypress",
        "wheel",
        "scroll",
        "touchstart",
        "touchmove",
        "touchend",
        "touchcancel"
      ]
    },
    "html/Element_appendChild":  {"category": "element_method", "js_member": "appendChild"},
    "html/Element_classList":    {"category": "element_property", "js_member": "classList"},
    "html/Element_cloneNode":    {"category": "element_method", "js_member": "cloneNode"},
    "html/Element_dataset":      {"category": "element_property", "js_member": "dataset"},
    "html/Element_disabled":     {"category": "element_property", "js_member": "disabled"},
    "html/Element_dispatchEvent":{"category": "element_method", "js_member": "dispatchEvent"},
    "html/Element_getAttribute": {"category": "element_method", "js_member": "getAttribute"},
    "html/Element_getBoundingClientRect": {"category": "element_method", "js_member": "getBoundingClientRect"},
    "html/Element_hidden":       {"category": "element_property", "js_member": "hidden"},
    "html/Element_insertBefore": {"category": "element_method", "js_member": "insertBefore"},
    "html/Element_nodeName":     {"category": "element_property", "js_member": "nodeName"},
    "html/Element_nodeType":     {"category": "element_property", "js_member": "nodeType"},
    "html/Element_offsetWidth":  {"category": "element_property", "js_member": "offsetWidth"},
    "html/Element_removeAttribute": {"category": "element_method", "js_member": "removeAttribute"},
    "html/Element_removeChild":  {"category": "element_method", "js_member": "removeChild"},
    "html/Element_replaceChild": {"category": "element_method", "js_member": "replaceChild"},
    "html/Element_setAttribute": {"category": "element_method", "js_member": "setAttribute"},
    "html/Element_setPointerCapture": {"category": "element_method", "js_member": "setPointerCapture"},
    "html/Element_textContent":  {"category": "element_property", "js_member": "textContent"},
    "html/Element_value":        {"category": "element_property", "js_member": "value"},

    "html/document_addEventListener": {"category": "document_member", "js_member": "addEventListener"},
    "html/document_createElement":    {"category": "document_member", "js_member": "createElement", "expected_bridge_calls": ["createCol", "createLabel", "createToggleButton", "createTextEditor", "createFader", "createCheckbox", "createCombo", "createCanvas", "createProgress", "createPanel"]},
    "html/document_createTextNode":   {"category": "document_member", "js_member": "createTextNode"},
    "html/document_getElementById":   {"category": "document_member", "js_member": "getElementById"},
    "html/document_querySelector":    {"category": "document_member", "js_member": "querySelector"},

    "html/article":  {"category": "html_tag", "tag": "article",  "expected_bridge_calls": ["createCol"]},
    "html/aside":    {"category": "html_tag", "tag": "aside",    "expected_bridge_calls": ["createCol"]},
    "html/button":   {"category": "html_tag", "tag": "button",   "expected_bridge_calls": ["createToggleButton"]},
    "html/canvas":   {"category": "html_tag", "tag": "canvas",   "expected_bridge_calls": ["createCanvas"]},
    "html/details":  {"category": "html_tag", "tag": "details",  "expected_bridge_calls": ["createCol"]},
    "html/dialog":   {"category": "html_tag", "tag": "dialog",   "expected_bridge_calls": ["createPanel"]},
    "html/div":      {"category": "html_tag", "tag": "div",      "expected_bridge_calls": ["createCol"]},
    "html/footer":   {"category": "html_tag", "tag": "footer",   "expected_bridge_calls": ["createCol"]},
    "html/h1":       {"category": "html_tag", "tag": "h1",       "expected_bridge_calls": ["createLabel", "setFontSize", "setFontWeight"]},
    "html/h2":       {"category": "html_tag", "tag": "h2",       "expected_bridge_calls": ["createLabel", "setFontSize", "setFontWeight"]},
    "html/h3":       {"category": "html_tag", "tag": "h3",       "expected_bridge_calls": ["createLabel", "setFontSize", "setFontWeight"]},
    "html/h4":       {"category": "html_tag", "tag": "h4",       "expected_bridge_calls": ["createLabel", "setFontSize", "setFontWeight"]},
    "html/h5":       {"category": "html_tag", "tag": "h5",       "expected_bridge_calls": ["createLabel", "setFontSize", "setFontWeight"]},
    "html/h6":       {"category": "html_tag", "tag": "h6",       "expected_bridge_calls": ["createLabel", "setFontSize", "setFontWeight"]},
    "html/header":   {"category": "html_tag", "tag": "header",   "expected_bridge_calls": ["createCol"]},
    "html/hr":       {"category": "html_tag", "tag": "hr",       "expected_bridge_calls": ["createCol", "setFlex", "setBackground"]},
    "html/img":      {"category": "html_tag", "tag": "img",      "expected_bridge_calls": ["createLabel"]},
    "html/input":    {"category": "html_tag", "tag": "input",    "expected_bridge_calls": ["createTextEditor", "createFader", "createCheckbox"]},
    "html/label":    {"category": "html_tag", "tag": "label",    "expected_bridge_calls": ["createLabel"]},
    "html/main":     {"category": "html_tag", "tag": "main",     "expected_bridge_calls": ["createCol"]},
    "html/nav":      {"category": "html_tag", "tag": "nav",      "expected_bridge_calls": ["createCol"]},
    "html/p":        {"category": "html_tag", "tag": "p",        "expected_bridge_calls": ["createLabel"]},
    "html/progress": {"category": "html_tag", "tag": "progress", "expected_bridge_calls": ["createProgress"]},
    "html/section":  {"category": "html_tag", "tag": "section",  "expected_bridge_calls": ["createCol"]},
    "html/select":   {"category": "html_tag", "tag": "select",   "expected_bridge_calls": ["createCombo"]},
    "html/span":     {"category": "html_tag", "tag": "span",     "expected_bridge_calls": ["createLabel"]},
    "html/style":    {"category": "html_tag", "tag": "style",    "expected_bridge_calls": ["createCol", "setVisible"]},
    "html/svg":      {"category": "html_tag", "tag": "svg",      "expected_bridge_calls": ["createCol"]},
    "html/textarea": {"category": "html_tag", "tag": "textarea", "expected_bridge_calls": ["createTextEditor", "setMultiLine"]},

    "html/ARIA": {
      "category": "feature",
      "spec": "https://www.w3.org/TR/wai-aria-1.2/",
      "evidence": "aria-label / role route through bridge.setAccessibilityLabel / setAccessibilityRole to View::access_label_/role_ (PR #1641); state routing (aria-pressed/checked/disabled/hidden) is partial-deferred-access-state — the View has no state slot today"
    },
    "html/DocumentFragment": {
      "category": "feature",
      "spec": "https://dom.spec.whatwg.org/#documentfragment",
      "evidence": "createDocumentFragment + appendChild/removeChild covers the React reconciler hot path; full Range/Selection API is arch-text-editor-owns-selection by design"
    },
    "html/Event_constructor": {
      "category": "feature",
      "spec": "https://dom.spec.whatwg.org/#interface-event",
      "evidence": "_makeEvent factory exists; no `new Event(...)` constructor surface"
    },
    "html/StyleSheet_inline": {
      "category": "feature",
      "spec": "https://html.spec.whatwg.org/multipage/semantics.html#the-style-element",
      "evidence": "Inline <style> parsed and applied via _processStyleElement; selectors cover tag/.class/#id/[attr]/descendant/child/:hover (PRs #1345 + #1641); at-rules + cascade engine are arch-no-cascade-engine"
    }
  }
}
