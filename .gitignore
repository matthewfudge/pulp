# Legacy planning paths (now a submodule at planning/)
/.planning-repo/

# Per-machine Shipyard config (SSH host details, paths, secrets).
# The committed template lives at .shipyard.local/config.toml.example.
/.shipyard.local/config.toml

# Build artifacts
/build/
/build-*/
/out/

# pulp.toml is a per-developer per-project SDK pin generated by
# `pulp project init`. It should never live in the Pulp source tree.
# A CLI shell-out test (test_cli_shellout.cpp:1605-1624) creates one
# inside its temp Clock fixture; that pollution shipped on PR #1755
# and required hotfix #1757. tools/scripts/source_tree_pollution_check.py
# blocks it at pre-push too.
/pulp.toml

# Coverage profile leakage from interrupted ctest runs.
/default.profraw
**/*.profraw

# IDE
.vscode/
.idea/
*.xcworkspace/
*.xcuserdata/
xcuserdata/

# OS
.DS_Store
Thumbs.db

# Local debug/temp artifacts
/.tmp-pulp-demo-verification.png
/pulpgain-test-pencil-render.png
/pulp
/tokens.json
/examples/design-tool/.design-tool-*.tmp.js
# Companion-track U-1 — stray top-level artifacts observed in 2026-05-17
# audit. Already blocked from landing by --mode=root-allowlist but
# ignoring them here keeps `git status` quiet too.
/screenshot.png
/.mcp.json.disabled-*
/artifacts/


# Dependencies (fetched at build time)
/external/*/
# Exception: vendored deps committed to repo
!/external/nanosvg/
!/external/skia-build/
!/external/pugixml/
!/external/miniz/
!/external/cpp-httplib/
!/external/dr_libs/
!/external/tweetnacl/

# Node (for web/WASM builds)
node_modules/

# packages/pulp-react build artifacts (regenerated by `npm run build`)
/packages/pulp-react/dist/

# packages/pulp-react vitest v8 coverage output (pulp #1886 Phase 1).
# Regenerated by `npm run test:coverage`; CI uploads it as an
# artifact and to Codecov via .github/workflows/pulp-react-build.yml.
/packages/pulp-react/coverage/

# packages/pulp-import-ir build artifacts (regenerated by `pnpm build`)
/packages/pulp-import-ir/dist/
/packages/pulp-import-ir/pnpm-lock.yaml

# Rust (if Tauri tooling is used)
target/

# Python
__pycache__/
*.pyc
tools/deps/hosts.local.json

# Local CI runtime files
tools/local-ci/config.json
tools/local-ci/queue.json
tools/local-ci/results/

# Secrets
.env
.env.*
!.env.example
# Apple signing / notarization creds — see docs/guides/ios-dev-signing.md.
# Real creds live at ~/.config/pulp/secrets/ (chmod 600). Belt-and-
# suspenders against accidental commits inside the repo too.
secrets/
*.notary.env
*.p8
*.p12
# Keep the committed schema-only template; rule must come AFTER the
# broad `secrets/` glob above so the negation actually takes effect.
!templates/secrets/
!templates/secrets/notary.env.example
templates/secrets/notary.env
examples/web-demos/wasm-build/build/
/.private/
test/assets/
android/app/.cxx/
android/app/build/
android/local.properties
android/.gradle/
build-android/
android/.gradle/
android/app/.cxx/
android/app/build/
external/skia-src/
external/skia-build/android-gpu/

# External SDKs cloned by setup.sh / FetchContent — never committed.
external/AudioUnitSDK
external/vst3sdk
