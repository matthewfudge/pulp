{
  "targets": {
    "mac": {
      "type": "local",
      "enabled": true
    },
    "ubuntu": {
      "type": "ssh",
      "host": "<your-ubuntu-ssh-host>",
      "repo_path": "/home/<username>/Code/pulp-validate",
      "utm_fallback": {
        "vm_name": "<UTM VM name for Ubuntu>",
        "boot_wait_secs": 30,
        "ssh_retry_secs": 60
      }
    },
    "windows": {
      "type": "ssh",
      "host": "<your-windows-ssh-host>",
      "fallback_host": "<optional-secondary-host>",
      "repo_path": "C:\\Users\\<username>\\pulp-validate",
      "cmake_generator": "Visual Studio 17 2022",
      "cmake_platform": "x64",
      "cmake_generator_instance": "",
      "utm_fallback": {
        "vm_name": "<UTM VM name for Windows>",
        "boot_wait_secs": 60,
        "ssh_retry_secs": 120
      }
    }
  },
  "defaults": {
    "priority": "normal",
    "ship_priority": "high",
    "check_priority": "high",
    "ssh_timeout_secs": 5,
    "max_retries": 3,
    "retry_delay_secs": 30
  }
}
