#include <catch2/catch_test_macros.hpp>
#include <catch2/catch_approx.hpp>
#include <pulp/format/headless.hpp>
#include "{{HEADER_NAME}}"

using Catch::Approx;

TEST_CASE("{{PLUGIN_NAME}} processes audio") {
    pulp::format::HeadlessHost host({{NAMESPACE}}::create_{{FACTORY_NAME}});
    host.prepare(48000, 512);

    pulp::audio::Buffer<float> in(2, 512), out(2, 512);

    // Fill input with a test signal
    for (std::size_t i = 0; i < 512; ++i) {
        in.channel(0)[i] = 0.5f;
        in.channel(1)[i] = 0.5f;
    }

    auto iv = in.view();
    auto ov = out.view();
    host.process(ov, iv);

    // With Mix at 100%, output should equal processed signal
    REQUIRE(out.channel(0)[0] != 0.0f);
}

TEST_CASE("{{PLUGIN_NAME}} has correct descriptor") {
    pulp::format::HeadlessHost host({{NAMESPACE}}::create_{{FACTORY_NAME}});
    auto desc = host.descriptor();

    REQUIRE(desc.name == "{{PLUGIN_NAME}}");
    REQUIRE(desc.manufacturer == "{{MANUFACTURER}}");
    REQUIRE(desc.category == pulp::format::PluginCategory::Effect);
}

TEST_CASE("{{PLUGIN_NAME}} state round-trip") {
    pulp::format::HeadlessHost host({{NAMESPACE}}::create_{{FACTORY_NAME}});
    host.prepare(48000, 512);

    // Change a parameter
    host.state().set_value({{NAMESPACE}}::kMix, 50.0f);

    // Save and restore
    auto data = host.save_state();
    host.state().set_value({{NAMESPACE}}::kMix, 0.0f);
    REQUIRE(host.load_state(data));
    REQUIRE(host.state().get_value({{NAMESPACE}}::kMix) == Approx(50.0f));
}
