<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Audio recording (microphone input) -->
    <uses-permission android:name="android.permission.RECORD_AUDIO"/>

    <!-- Foreground service for background audio -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE"/>
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_MEDIA_PLAYBACK"/>
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_MICROPHONE"/>

    <!-- Android 14+ notification permission for FGS -->
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS"/>

    <!-- Bluetooth MIDI (API 31+) -->
    <uses-permission android:name="android.permission.BLUETOOTH_SCAN"
                     android:usesPermissionFlags="neverForLocation"/>
    <uses-permission android:name="android.permission.BLUETOOTH_CONNECT"/>

    <!-- Internet for license validation, analytics -->
    <uses-permission android:name="android.permission.INTERNET"/>

    <!-- Optional hardware features -->
    <uses-feature android:name="android.hardware.audio.pro" android:required="false"/>
    <uses-feature android:name="android.hardware.audio.low_latency" android:required="false"/>
    <uses-feature android:name="android.hardware.midi" android:required="false"/>
    <uses-feature android:name="android.hardware.vulkan.level" android:version="1" android:required="false"/>
    <uses-feature android:glEsVersion="0x00030000" android:required="false"/>

    <application
        android:name=".PulpApplication"
        android:allowBackup="true"
        android:label="Pulp"
        android:supportsRtl="true"
        android:extractNativeLibs="true"
        android:theme="@android:style/Theme.Material.Light.NoActionBar">

        <!-- Main activity — configChanges prevents destruction on rotation/fold -->
        <activity
            android:name=".PulpActivity"
            android:configChanges="orientation|screenSize|screenLayout|smallestScreenSize|keyboardHidden|keyboard|uiMode|density|fontScale|layoutDirection|locale|colorMode"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN"/>
                <category android:name="android.intent.category.LAUNCHER"/>
            </intent-filter>
        </activity>

        <!-- Foreground service for background audio processing -->
        <service
            android:name=".PulpAudioService"
            android:foregroundServiceType="mediaPlayback|microphone"
            android:exported="false"/>

        <!-- Virtual MIDI port service -->
        <service
            android:name=".midi.PulpMidiService"
            android:permission="android.permission.BIND_MIDI_DEVICE_SERVICE"
            android:exported="true">
            <intent-filter>
                <action android:name="android.media.midi.MidiDeviceService"/>
            </intent-filter>
            <meta-data
                android:name="android.media.midi.MidiDeviceService"
                android:resource="@xml/midi_device_info"/>
        </service>

    </application>
</manifest>
