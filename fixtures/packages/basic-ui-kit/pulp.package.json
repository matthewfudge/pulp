{
  "schema": "pulp-package-v1",
  "id": "dev.pulp.fixtures.basic-ui-kit",
  "name": "Basic UI Kit",
  "version": "0.1.0",
  "license": "MIT",
  "licenses": {
    "code": "MIT",
    "assets": "CC0-1.0"
  },
  "kind": ["ui-kit"],
  "audience": ["developer", "agent"],
