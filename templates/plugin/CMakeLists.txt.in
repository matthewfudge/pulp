# @PLUGIN_NAME@ — Pulp Plugin Project
# Generated by pulp_add_plugin()

cmake_minimum_required(VERSION 3.24)
project(@PLUGIN_NAME@ VERSION @VERSION@ LANGUAGES CXX)

# Find Pulp framework
find_package(Pulp REQUIRED)

# Plugin definition — all format targets generated automatically
pulp_add_plugin(@PLUGIN_NAME@
    FORMATS             @FORMATS@
    PLUGIN_NAME         "@PLUGIN_NAME@"
    BUNDLE_ID           "@BUNDLE_ID@"
    MANUFACTURER        "@MANUFACTURER@"
    VERSION             "@VERSION@"
    CATEGORY            @CATEGORY@
    PLUGIN_CODE         "@PLUGIN_CODE@"
    MANUFACTURER_CODE   "@MANUFACTURER_CODE@"
    SOURCES
        src/@PLUGIN_NAME_LOWER@.hpp
        src/vst3_entry.cpp
        src/clap_entry.cpp
        src/au_v2_entry.cpp
        src/main.cpp
)

# Tests
if(BUILD_TESTING)
    enable_testing()
    find_package(Catch2 3 REQUIRED)
    add_executable(@PLUGIN_NAME@_Test test/test_@PLUGIN_NAME_LOWER@.cpp)
    target_link_libraries(@PLUGIN_NAME@_Test PRIVATE @PLUGIN_NAME@_Core Catch2::Catch2WithMain)
    include(Catch)
    catch_discover_tests(@PLUGIN_NAME@_Test)
endif()
