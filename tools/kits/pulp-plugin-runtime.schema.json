{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://pulp.dev/schemas/pulp-plugin-runtime-v1.schema.json",
  "title": "Pulp Plugin Runtime Manifest",
  "type": "object",
  "additionalProperties": true,
  "required": ["schema", "pluginId", "content"],
  "properties": {
    "schema": {
      "const": "pulp.plugin-runtime.v1"
    },
    "pluginId": {
      "type": "string",
      "minLength": 1
    },
    "content": {
      "type": "object",
      "additionalProperties": true,
      "required": ["capabilities", "kinds"],
      "properties": {
        "capabilities": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string" },
          "uniqueItems": true
        },
        "kinds": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "enum": ["presets", "themes", "samples", "wavetables"]
          },
          "uniqueItems": true
        },
        "reload": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "hotReloadKinds": {
              "type": "array",
              "items": {
                "type": "string",
                "enum": ["presets", "themes", "samples", "wavetables"]
              },
              "uniqueItems": true
            },
            "manualRescanKinds": {
              "type": "array",
              "items": {
                "type": "string",
                "enum": ["presets", "themes", "samples", "wavetables"]
              },
              "uniqueItems": true
            }
          }
        }
      }
    }
  }
}
