# PulpConfig.cmake — find_package(Pulp) support for installed SDK consumers.
#
# PulpConfig is a thin coordinator. Package init, platform detection,
# IMPORTED-target recreation, debug-SDK guards, and WebGPU import-lib
# recovery each live in focused sibling modules under
# `${CMAKE_CURRENT_LIST_DIR}/`, all installed alongside this file.

@PACKAGE_INIT@

include(CMakeFindDependencyMacro)
include("${CMAKE_CURRENT_LIST_DIR}/PulpAAX.cmake")

set(PULP_VERSION "@PROJECT_VERSION@")
get_filename_component(PULP_SDK_DIR "${CMAKE_CURRENT_LIST_DIR}/../../.." ABSOLUTE)
set(PULP_SDK_STATIC_LIBRARY_PREFIX "@CMAKE_STATIC_LIBRARY_PREFIX@")
set(PULP_SDK_STATIC_LIBRARY_SUFFIX "@CMAKE_STATIC_LIBRARY_SUFFIX@")
set(PULP_SDK_SHARED_LIBRARY_PREFIX "@CMAKE_SHARED_LIBRARY_PREFIX@")
set(PULP_SDK_SHARED_LIBRARY_SUFFIX "@CMAKE_SHARED_LIBRARY_SUFFIX@")
set(PULP_SDK_LIBRARY_DIR "${PULP_SDK_DIR}/@CMAKE_INSTALL_LIBDIR@")

set(PULP_CLAP_INCLUDE_DIR "${PULP_SDK_DIR}/external/clap/include")
set(PULP_LV2_INCLUDE_DIR "${PULP_SDK_DIR}/external/lv2/include")
set(PULP_VST3_INCLUDE_DIR "${PULP_SDK_DIR}/external/vst3sdk")
set(PULP_AUSDK_INCLUDE_DIR "${PULP_SDK_DIR}/external/AudioUnitSDK/include")
set(PULP_SOURCE_INCLUDE_DIR "${PULP_SDK_DIR}/src")
set(PULP_FORMAT_SOURCE_DIR "${PULP_SDK_DIR}/src/pulp/format")
set(PULP_AUV3_TEMPLATE_DIR "${PULP_SDK_DIR}/templates/auv3")
set(PULP_IOS_AUV3_TEMPLATE_DIR "${PULP_SDK_DIR}/templates/ios-auv3")

# Platform detection → PULP_APPLE / PULP_LINUX / PULP_WINDOWS / etc.
include("${CMAKE_CURRENT_LIST_DIR}/PulpPlatformConfig.cmake")

# Linux PkgConfig::* IMPORTED target recreation. No-op on non-Linux.
include("${CMAKE_CURRENT_LIST_DIR}/PulpPkgConfigImports.cmake")

# Expose pulp_link_fontconfig_after_skia() to downstream consumers. The
# chrome/m144 Skia archive references fontconfig (Fc*) symbols, and GNU ld is
# single-pass, so a consumer linking libskia.a must re-mention `-lfontconfig`
# AFTER the archive or the link fails (undefined FcCharSetHasChar, FcInit, …).
# Pulp's own app targets use this; a foreign consumer (e.g. pulp-view-embed)
# calls it on its Skia-linking executables on Linux. No-op on non-Linux.
include("${CMAKE_CURRENT_LIST_DIR}/PulpLinkFontconfig.cmake")

# Pulp::canvas is a static SDK target and its build exports retain
# LINK_ONLY references to private static dependencies. SheenBidi installs its
# own package into the same SDK prefix, so load it before PulpTargets.cmake
# validates referenced imported targets.
find_dependency(SheenBidi CONFIG)

# Pulp::canvas links system ICU on Linux (UNIX-not-Apple-not-Android): the
# bundled Skia statically links SkUnicode but does not export ICU's symbols, so
# core/canvas links ICU::uc/i18n/data. Those are PRIVATE, but a STATIC lib
# propagates private link deps into its exported interface — so a downstream
# find_package(Pulp) must re-find ICU or PulpTargets.cmake errors with
# "target ICU::uc not found". macOS bundles ICU (libicucore) implicitly, so this
# is Linux-only. (Surfaced building pulp-view-embed against the Linux SDK.)
if(UNIX AND NOT APPLE AND NOT ANDROID)
    find_dependency(ICU COMPONENTS uc i18n data)
endif()

# The Pulp SDK is built and installed in the Release configuration only.
# When a downstream plugin is built in Debug / MinSizeRel / RelWithDebInfo
# (or the Visual Studio multi-config generator picks those configs), CMake
# needs to know to use the Release configuration of Pulp's imported
# targets. Without this, the Visual Studio generator errors with
# "IMPORTED_IMPLIB not set for imported target 'webgpu' configuration
# 'MinSizeRel'" etc.
#
# Set CMAKE_MAP_IMPORTED_CONFIG_<CONFIG>=Release for every non-Release
# config unless the consuming project has already overridden it.
foreach(_pulp_cfg Debug MinSizeRel RelWithDebInfo)
    if(NOT DEFINED CMAKE_MAP_IMPORTED_CONFIG_${_pulp_cfg})
        set(CMAKE_MAP_IMPORTED_CONFIG_${_pulp_cfg} "Release;")
    endif()
endforeach()
unset(_pulp_cfg)

# Debug-SDK perf-killer guard (task #35) + any future find_package-time
# safety checks.
include("${CMAKE_CURRENT_LIST_DIR}/PulpSdkGuards.cmake")

# `webgpu` IMPORTED target + target_copy_webgpu_binaries() helper.
include("${CMAKE_CURRENT_LIST_DIR}/PulpWebGpuImportedTarget.cmake")

if(EXISTS "${PULP_SDK_DIR}/external/skia-build")
    set(_pulp_saved_skia_dir "${SKIA_DIR}")
    set(SKIA_DIR "${PULP_SDK_DIR}/external/skia-build")
    include("${CMAKE_CURRENT_LIST_DIR}/FindSkia.cmake")
    if(DEFINED _pulp_saved_skia_dir)
        set(SKIA_DIR "${_pulp_saved_skia_dir}")
    else()
        unset(SKIA_DIR)
    endif()
    unset(_pulp_saved_skia_dir)
endif()

if(NOT TARGET SDL3::Headers)
    set(_pulp_sdl3_headers_dir "${PULP_SDK_DIR}/external/SDL3/include")
    if(EXISTS "${_pulp_sdl3_headers_dir}")
        add_library(SDL3::Headers INTERFACE IMPORTED)
        set_target_properties(SDL3::Headers PROPERTIES
            INTERFACE_INCLUDE_DIRECTORIES "${_pulp_sdl3_headers_dir}"
        )
    endif()
endif()

include("${CMAKE_CURRENT_LIST_DIR}/PulpTargets.cmake")

if(TARGET Pulp::yogacore)
    set_target_properties(Pulp::yogacore PROPERTIES
        INTERFACE_INCLUDE_DIRECTORIES "${PULP_SDK_DIR}/include"
    )
endif()

set(PULP_HAS_CLAP FALSE)
if(TARGET Pulp::clap)
    set(PULP_HAS_CLAP TRUE)
endif()

set(PULP_HAS_LV2 FALSE)
if(TARGET Pulp::lv2-headers)
    set(PULP_HAS_LV2 TRUE)
endif()

set(PULP_HAS_VST3 FALSE)
if(TARGET Pulp::vst3-sdk)
    set(PULP_HAS_VST3 TRUE)
endif()

set(PULP_HAS_AUSDK FALSE)
if(TARGET Pulp::ausdk)
    set(PULP_HAS_AUSDK TRUE)
endif()

set(PULP_HAS_SDL3 FALSE)
if(TARGET Pulp::sdl3-static)
    set(PULP_HAS_SDL3 TRUE)
endif()

set(PULP_HAS_YOGA FALSE)
if(TARGET Pulp::yogacore)
    set(PULP_HAS_YOGA TRUE)
endif()

set(PULP_HAS_WEBGPU FALSE)
if(TARGET webgpu)
    set(PULP_HAS_WEBGPU TRUE)
endif()

set(PULP_HAS_SKIA FALSE)
if(TARGET skia::skia)
    set(PULP_HAS_SKIA TRUE)
endif()

set(PULP_ENABLE_GPU FALSE)
if(TARGET Pulp::render)
    set(PULP_ENABLE_GPU TRUE)
endif()

if(NOT DEFINED PULP_ENABLE_AAX)
    set(PULP_ENABLE_AAX FALSE)
endif()
if(PULP_ENABLE_AAX)
    pulp_configure_aax_sdk()
else()
    set(PULP_HAS_AAX FALSE)
    set(PULP_AAX_SDK_DIR_REAL "")
endif()

include("${CMAKE_CURRENT_LIST_DIR}/PulpUtils.cmake")

check_required_components(Pulp)
