// build_info.hpp — generated by CMake at configure time.
//
// Do not edit. Source template: build_info.hpp.in. Generated header
// lives under <build>/generated/pulp/runtime/build_info.hpp and is
// included via the standard `<pulp/runtime/build_info.hpp>` path.
//
// Per sudara "Big List of JUCE Tips" #9: a build stamp visible in
// the running app is the cheapest "which version is this?" tool.
//
#pragma once

#include <string_view>

namespace pulp::runtime {

/// Build configuration ("Debug", "Release", "RelWithDebInfo", ...).
/// Whatever CMake's @c CMAKE_BUILD_TYPE was at configure time; empty
/// for multi-config generators that pick the config at build time.
inline constexpr std::string_view kBuildType   = "@PULP_BUILD_TYPE@";

/// ISO 8601 UTC timestamp of the CMake configure step that produced
/// this header. Useful to confirm a fresh build picked up your edits.
inline constexpr std::string_view kBuildIso8601 = "@PULP_BUILD_ISO8601@";

/// Short git SHA of the working tree at configure time. Empty when
/// the source tree is not a git checkout (e.g. distribution tarball).
inline constexpr std::string_view kGitSha      = "@PULP_GIT_SHA@";

/// True when the working tree had uncommitted changes at configure
/// time. Renders as " (dirty)" in a typical stamp string.
inline constexpr bool kGitDirty                = @PULP_GIT_DIRTY@;

/// Pulp SDK version (from the root CMakeLists.txt `project(...)`).
inline constexpr std::string_view kSdkVersion  = "@PULP_VERSION@";

/// Convenience: ready-to-render label
/// (`"0.135.1 (Release, abc1234, 2026-05-18T22:00:00Z)"`).
inline constexpr std::string_view kStampLabel  = "@PULP_BUILD_STAMP@";

} // namespace pulp::runtime
